{
  "name": "dreamlist",
  "version": "1.0.1",
  "private": true,
  "description": "DreamList - persoenliche ToDo-Liste",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@uiw/color-convert": "^2.10.1",
    "@uiw/react-color-shade-slider": "^2.10.1",
    "@uiw/react-color-wheel": "^2.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^32.0.1",
    "electron-builder": "^25.0.5",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4",
    "vite": "^5.3.5",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.dreamlist.app",
    "productName": "DreamList",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "Logo.ico"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "portable"
      ],
      "icon": "Logo.ico"
    },
    "portable": {
      "artifactName": "DreamList-${version}-portable.exe"
    }
  }
}
